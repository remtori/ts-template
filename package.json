{
  "name": "repo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"pnpm -F @repo/client dev\" \"pnpm -F @repo/server dev\"",
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "test": "pnpm -r test",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "db:generate": "pnpm -F @repo/server db:generate"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f",
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@typescript/native-preview": "7.0.0-dev.20260521.1",
    "concurrently": "^9.2.1",
    "oxlint": "^1.66.0"
  }
}
