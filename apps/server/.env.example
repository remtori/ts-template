# TS Template server config. Copy to `apps/server/.env` for local overrides.

# SQLite database directory. Defaults to `apps/server/data`.
DATA_DIR=

# Drizzle migrations directory. Defaults to `apps/server/db/migrations`.
DB_MIGRATIONS_DIR=

# HTTP server port.
PORT=3000

# Client build output for production. Docker sets this automatically.
STATIC_DIR=
