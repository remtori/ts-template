{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 4,
		"lineWidth": 140
	},
	"linter": {
		"enabled": false
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [[":URL:", ":NODE:", ":PACKAGE_WITH_PROTOCOL:", ":PACKAGE:"], ":BLANK_LINE:", [":ALIAS:", ":PATH:"]]
					}
				}
			}
		}
	},
	"files": {
		"includes": ["**/*.ts", "**/*.tsx", "**/*.css", "**/*.md", "!**/node_modules", "!**/dist", "!**/.vite", "!**/assets"]
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"jsxQuoteStyle": "single",
			"trailingCommas": "es5"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
